      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Green_destination Assignment)' name='federated.0zop3j80sxlv20107puot19n1bbm' />
          </datasources>
          <datasource-dependencies datasource='federated.0zop3j80sxlv20107puot19n1bbm'>
            <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
            <column datatype='string' name='[Attrition]' role='dimension' type='nominal' />
            <column caption='Updated Attrition Count' datatype='integer' name='[Calculation_2321929563303936]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Attrition]=&quot;Yes&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='Updated Age' datatype='string' name='[Calculation_2321929591185414]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF[Age]&lt;30 THEN&quot;Under 30&quot;&#13;&#10;ELSEIF [Age]&lt;=40 THEN&quot;30-40&quot;&#13;&#10;ELSEIF[Age]&lt;=50 THEN &quot;41-50&quot;&#13;&#10;ELSE &quot;50+&quot;&#13;&#10;END' />
            </column>
            <column caption='Attiration Rate %' datatype='real' name='[Calculation_2321929592684551]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_2321929563303936]) / COUNT([EmployeeCount]) * 100' />
            </column>
            <column caption='Employee Count' datatype='integer' name='[EmployeeCount]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_2321929591185414]' derivation='None' name='[none:Calculation_2321929591185414:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2321929592684551]' derivation='User' name='[usr:Calculation_2321929592684551:qk]' pivot='key' type='quantitative' />
